---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Cross-functional ownership"
  description="Cross-functional responsibilities and how engineering, manufacturing, quality, and partners work together."
>
  <div class="site-container pt-28 pb-20">
    <div class="max-w-4xl">
      <h1 class="mb-4 text-5xl font-semibold tracking-[-0.04em] text-foreground md:text-6xl">
        Cross-functional ownership
      </h1>
      <p class="max-w-3xl text-base leading-relaxed text-text-secondary md:text-lg">
        Use this page to highlight how you lead across engineering, production, suppliers, and quality—from early design through stable manufacturing.
      </p>
    </div>

    <section class="mt-14" aria-label="Cross-functional responsibilities">
      <div
        class="theme-panel rounded-[1.25rem] border border-dashed border-border/80 p-10 text-center text-sm leading-relaxed text-text-muted md:p-14"
      >
        <p>Add your responsibilities, examples, and visuals here.</p>
      </div>
    </section>
  </div>
</BaseLayout>
