---
import BaseLayout from '../layouts/BaseLayout.astro';
import { AboutTOC } from '../components/AboutTOC';
import { AvatarColumn } from '../components/AvatarColumn';
import { WorkExperienceTimeline } from '../components/WorkExperienceTimeline';
import { SkillsGrid } from '../components/SkillsGrid';
import { AboutMetrics } from '../components/AboutMetrics';
import { getCollection } from 'astro:content';
import { siteConfig } from '../config/site';
import { aboutTitle, aboutBioParagraphs, aboutNameNote } from '../data/aboutContent';
import { workCollectionToTimelinePayload } from '../lib/workTimelinePayload';

const workEntriesPlain = workCollectionToTimelinePayload(await getCollection('work'));
---

<BaseLayout title="About">
  <div class="site-container pb-20 pt-10">
    <div class="relative flex gap-6">
      <AboutTOC client:visible />

      <div class="flex min-w-0 flex-1 gap-8">
        <AvatarColumn client:load />

        <div class="min-w-0 flex-1 space-y-0">
          <section
            id="intro"
            class="scroll-reveal space-y-2 bg-[#f5f5f7] py-8 dark:bg-[#1C1C1E] sm:py-10"
          >
            <div class="max-w-3xl space-y-2">
              <h1 class="text-4xl font-semibold tracking-tight text-[#1d1d1f] md:text-5xl dark:text-white">
                {siteConfig.name}
              </h1>
              <p class="text-sm leading-relaxed text-[#86868b] dark:text-[#A1A1A6]">
                {aboutNameNote}
              </p>
            </div>
            <p class="pt-2 text-xl text-[#86868b] dark:text-[#A1A1A6]">
              {siteConfig.role}
            </p>
            <p class="text-base text-muted-foreground">
              {siteConfig.location}
            </p>
            <h2 class="pt-4 text-xl font-bold tracking-tight text-primary-accent">
              {aboutTitle}
            </h2>
            <div class="max-w-3xl space-y-3 text-sm leading-relaxed text-body-text">
              {aboutBioParagraphs.map((p) => (
                <p>{p}</p>
              ))}
            </div>
            <div class="pt-4">
              <AboutMetrics client:load />
            </div>
            <div class="pt-6">
              <a
                href={`mailto:${siteConfig.social.email}`}
                class="inline-flex items-center gap-2 rounded-xl border-2 border-primary-accent/35 bg-primary-accent/10 px-6 py-3 text-sm font-semibold text-foreground shadow-sm transition-all duration-300 hover:border-primary-accent hover:bg-primary-accent hover:text-primary-foreground hover:shadow-md"
              >
                Schedule a call →
              </a>
            </div>
          </section>

          <section
            id="experience"
            class="scroll-reveal mt-12 space-y-8 border-t border-border bg-white py-8 dark:bg-black sm:py-10 lg:mt-16"
          >
            <h2 class="text-2xl font-semibold tracking-tight text-[#1d1d1f] dark:text-white">Work experience</h2>
            <WorkExperienceTimeline entries={workEntriesPlain} client:load />
          </section>

          <section
            id="skills"
            class="scroll-reveal mt-12 space-y-8 border-t border-border bg-[#f5f5f7] py-8 dark:bg-[#1C1C1E] sm:py-10 lg:mt-16"
          >
            <h2 class="text-2xl font-semibold tracking-tight text-[#1d1d1f] dark:text-white">Skills</h2>
            <SkillsGrid client:visible />
          </section>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
