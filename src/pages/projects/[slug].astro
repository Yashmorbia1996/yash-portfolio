---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { ProjectCard } from '../../components/ProjectCard';
import { EvolutionTimeline } from '../../components/EvolutionTimeline';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const allProjects = await getCollection('projects');
  return allProjects.map((project) => ({
    params: { slug: project.id },
    props: {
      project,
      relatedProjects: allProjects
        .filter((p) => p.id !== project.id)
        .slice(0, 2),
    },
  }));
}

const { project, relatedProjects } = Astro.props;
const { Content } = await render(project);

const formattedDate = project.data.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
});
---

<BaseLayout title={project.data.title} description={project.data.summary}>
  <div class="site-container pt-24 pb-20">
    <!-- Back link -->
    <a
      href="/projects"
      class="inline-flex items-center gap-2 text-sm text-muted-foreground hover:text-foreground transition-colors duration-200 mb-10"
    >
      ← Projects
    </a>

    <!-- Date -->
    <time class="text-xs text-muted-foreground block mb-3">{formattedDate}</time>

    <!-- Title -->
    <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight text-foreground mb-6 max-w-3xl">
      {project.data.title}
    </h1>

    <!-- Tags -->
    <div class="flex flex-wrap gap-2 mb-6">
      {project.data.tags.map((tag) => (
        <span class="rounded-full text-xs px-2.5 py-0.5 border border-border text-muted-foreground">{tag}</span>
      ))}
    </div>

    <!-- Project links -->
    {(project.data.liveUrl || project.data.repoUrl) && (
      <div class="flex items-center gap-4 mb-10">
        {project.data.repoUrl && (
          <a
            href={project.data.repoUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 text-sm text-muted-foreground hover:text-foreground transition-colors duration-200"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
            </svg>
            GitHub
          </a>
        )}
        {project.data.liveUrl && (
          <a
            href={project.data.liveUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 text-sm text-primary-accent hover:opacity-80 transition-opacity duration-200"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M15 3h6v6"/>
              <path d="M10 14 21 3"/>
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
            </svg>
            Live site
          </a>
        )}
      </div>
    )}

    <!-- Cover image -->
    <div class="relative mt-10 mb-12">
      <div class="rounded-3xl overflow-hidden aspect-video bg-muted/50">
        {project.data.cover ? (
          <img
            src={project.data.cover}
            alt={project.data.title}
            class="w-full h-full object-cover"
          />
        ) : (
          <div class="w-full h-full flex items-center justify-center text-muted-foreground/30">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
              <rect width="18" height="18" x="3" y="3" rx="2" ry="2"/>
              <circle cx="9" cy="9" r="2"/>
              <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/>
            </svg>
          </div>
        )}
      </div>
    </div>

    <!-- Design Evolution Timeline -->
    <div class="max-w-3xl mx-auto mb-16 border-t border-border pt-12">
      <EvolutionTimeline client:visible />
    </div>

    <!-- MDX content -->
    <div class="max-w-2xl mx-auto">
      <div class="prose prose-neutral dark:prose-invert max-w-none prose-content">
        <Content />
      </div>
    </div>

    <!-- Related projects -->
    {relatedProjects.length > 0 && (
      <div class="mt-20 pt-12 border-t border-border">
        <h2 class="text-xl font-semibold mb-8 text-muted-foreground">More projects</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {relatedProjects.map((p) => (
            <ProjectCard
              title={p.data.title}
              summary={p.data.summary}
              tags={p.data.tags}
              slug={p.id}
              cover={p.data.cover}
              liveUrl={p.data.liveUrl}
              repoUrl={p.data.repoUrl}
              date={p.data.date}
              duration={p.data.duration}
              client:visible
            />
          ))}
        </div>
      </div>
    )}
  </div>
</BaseLayout>
