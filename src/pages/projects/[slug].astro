---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Badge } from '../../components/ui/badge';
import { Button } from '../../components/ui/button';
import { getCollection, render } from 'astro:content';
import { ArrowLeft, ExternalLink } from 'lucide-react';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);

const formattedDate = project.data.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
});
---

<BaseLayout title={project.data.title} description={project.data.summary}>
  <div class="site-container pt-28 pb-20">
    <div class="max-w-2xl mx-auto">
      <!-- Back link -->
      <Button variant="ghost" size="sm" asChild client:load>
        <a href="/projects" class="mb-8 inline-flex items-center gap-1 text-muted-foreground hover:text-foreground">
          <ArrowLeft className="h-4 w-4" />
          All projects
        </a>
      </Button>

      <!-- Header -->
      <div class="mb-8 mt-4">
        <div class="flex flex-wrap gap-1.5 mb-4">
          {project.data.tags.map((tag) => (
            <Badge variant="secondary" client:load>{tag}</Badge>
          ))}
        </div>
        <h1 class="font-heading text-4xl md:text-5xl font-normal tracking-[-0.03em] mb-3">
          {project.data.title}
        </h1>
        <p class="text-muted-foreground text-lg leading-relaxed mb-4">
          {project.data.summary}
        </p>
        <div class="flex items-center gap-4">
          <time class="text-sm text-muted-foreground">{formattedDate}</time>
          {project.data.liveUrl && (
            <Button variant="outline" size="sm" asChild client:load>
              <a href={project.data.liveUrl} target="_blank" rel="noopener noreferrer">
                View live <ExternalLink className="ml-1 h-3 w-3" />
              </a>
            </Button>
          )}
        </div>
      </div>

      <!-- Cover image -->
      {project.data.cover && (
        <img
          src={project.data.cover}
          alt={project.data.title}
          class="w-full rounded-xl mb-10 shadow-card aspect-video object-cover"
        />
      )}

      <!-- MDX content -->
      <div class="prose prose-neutral dark:prose-invert max-w-none prose-content">
        <Content />
      </div>
    </div>
  </div>
</BaseLayout>
