---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { WorkProjectsCarousel } from '../../components/WorkProjectsCarousel';
import CadSimulationProjects from '../../components/CadSimulationProjects.astro';
import { allProjectsCarouselProjects } from '../../data/portfolioCarousel';
---

<BaseLayout title="Projects" description="Selected work projects and supporting engineering portfolio pieces.">
  <!-- Full-width white: page title (same rhythm as white → gray break on homepage) -->
  <div class="w-full bg-white dark:bg-black">
    <div class="site-container pt-14 pb-10 md:pb-12">
      <div class="max-w-4xl">
        <h1 class="mb-4 text-5xl font-semibold tracking-tight text-[#1d1d1f] md:text-6xl dark:text-white">
          Projects
        </h1>
        <p class="text-base leading-relaxed text-[#86868b] md:text-lg md:whitespace-nowrap dark:text-[#A1A1A6]">
          A fast-scanning catalog of selected work, supporting engineering projects, and broader technical exploration.
        </p>
      </div>
    </div>
  </div>

  <!-- Full-width Apple gray: work projects carousel (white cards float on this band) -->
  <section class="w-full bg-[#f5f5f7] py-12 dark:bg-[#1C1C1E] md:py-16" aria-label="Selected work projects">
    <div class="site-container">
      <div class="mb-8 max-w-none space-y-3">
        <p class="max-w-none text-sm leading-relaxed text-text-muted md:whitespace-nowrap">
          Disclosure: Work project details are limited to non-proprietary information. Images shown are public, recreated, or selected to avoid confidential content.
        </p>
      </div>

      <WorkProjectsCarousel
        client:load
        frame="work"
        projects={allProjectsCarouselProjects.map((p) => ({
          ...p,
          tags: [...p.tags],
          coverSlides: p.coverSlides ? [...p.coverSlides] : undefined,
        }))}
      />
    </div>
  </section>

  <!-- Full-width white: CAD & Simulation -->
  <section
    class="w-full border-t border-border bg-white py-12 dark:bg-black md:py-16"
    aria-label="CAD and simulation portfolio"
  >
    <div class="site-container pb-20">
      <div class="w-full max-w-none space-y-4">
        <h2 class="theme-section-title text-4xl font-semibold tracking-tight md:text-5xl">
          CAD & Simulation
        </h2>
        <p class="text-base leading-relaxed text-text-secondary">
          Breadth work that shows design exploration, simulation thinking, and supporting technical range beyond the headline case studies.
        </p>
        <div class="mt-6 w-full sm:mt-8">
          <div
            class="w-full rounded-2xl border border-border/80 bg-surface-elevated/50 p-5 sm:p-6"
          >
            <p class="font-mono text-[10px] font-semibold uppercase tracking-[0.16em] text-text-muted sm:text-[11px]">
              Work in progress
            </p>
            <p class="mt-2 text-pretty text-sm leading-relaxed text-text-secondary sm:text-base">
              I treat this area as a living set of studies, not a finished list. I keep an eye out for new projects to
              sharpen simulation and CAD skills, and I make time to learn and practice additional CAD and CAE tools so my
              workflow stays close to what teams use in the field.
            </p>
          </div>
        </div>
      </div>

      <CadSimulationProjects />
    </div>
  </section>
</BaseLayout>
