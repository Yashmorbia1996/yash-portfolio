---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { WorkProjectsCarousel } from '../../components/WorkProjectsCarousel';
import {
  allProjectsCarouselProjects,
  cadCarouselProjects,
} from '../../data/portfolioCarousel';
---

<BaseLayout title="Projects" description="Selected work projects and supporting engineering portfolio pieces.">
  <div class="site-container pt-14 pb-20">
    <div class="max-w-4xl">
      <h1 class="text-5xl md:text-6xl font-semibold tracking-[-0.04em] text-foreground mb-4">
        Projects
      </h1>
      <p class="max-w-3xl text-base leading-relaxed text-text-secondary md:text-lg">
        A fast-scanning catalog of selected work, supporting engineering projects, and broader technical exploration.
      </p>
    </div>

    <section class="mt-14">
      <div class="mb-8 max-w-3xl space-y-3">
        <h2 class="theme-section-title text-3xl font-semibold tracking-[-0.03em] md:text-4xl">
          Projects
        </h2>
        <p class="max-w-none text-sm leading-relaxed text-text-muted md:whitespace-nowrap">
          Disclosure: Work project details are limited to non-proprietary information. Images shown are public, recreated, or selected to avoid confidential content.
        </p>
      </div>

      <WorkProjectsCarousel
        client:load
        projects={allProjectsCarouselProjects.map((p) => ({
          ...p,
          tags: [...p.tags],
          coverSlides: p.coverSlides ? [...p.coverSlides] : undefined,
        }))}
      />
    </section>

    <section class="mt-20 border-t border-border pt-16">
      <div class="max-w-4xl space-y-4">
        <h2 class="theme-section-title text-4xl font-semibold tracking-[-0.03em] md:text-5xl">
          CAD & Simulation
        </h2>
        <p class="max-w-3xl text-base leading-relaxed text-text-secondary">
          Breadth work that shows design exploration, simulation thinking, and supporting technical range beyond the headline case studies.
        </p>
      </div>

      <WorkProjectsCarousel
        client:load
        eyebrow="CAD & Simulation"
        ctaLabel="Read more"
        projects={cadCarouselProjects.map((project) => ({
          title: project.title,
          slug: project.slug,
          eyebrow: project.eyebrow,
          context: project.context,
          problem: project.problem,
          action: project.action,
          result: project.result,
          summary: project.summary,
          studyLinks: project.studyLinks ? [...project.studyLinks] : undefined,
          tags: [...project.tags],
          cover: project.cover,
        }))}
      />
    </section>
  </div>
</BaseLayout>
