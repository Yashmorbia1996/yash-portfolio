---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Badge } from '../../components/ui/badge';
import { Button } from '../../components/ui/button';
import { getCollection, render } from 'astro:content';
import { ArrowLeft } from 'lucide-react';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const formattedDate = post.data.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={post.data.title} description={post.data.summary}>
  <div class="w-full bg-white dark:bg-black">
    <div class="site-container pt-14 pb-8 md:pb-10">
      <div class="mx-auto max-w-2xl">
        <Button variant="ghost" size="sm" asChild client:load>
          <a href="/blog" class="mb-8 inline-flex items-center gap-1 text-[#86868b] hover:text-[#1d1d1f] dark:text-[#A1A1A6] dark:hover:text-white">
            <ArrowLeft className="h-4 w-4" />
            All posts
          </a>
        </Button>

        <div class="mb-8 mt-4">
          <time class="mb-4 block text-sm text-[#86868b] dark:text-[#A1A1A6]">{formattedDate}</time>
          <h1 class="mb-3 font-heading text-4xl font-semibold tracking-tight text-[#1d1d1f] md:text-5xl dark:text-white">
            {post.data.title}
          </h1>
          <p class="mb-4 text-lg leading-relaxed text-[#86868b] dark:text-[#A1A1A6]">
            {post.data.summary}
          </p>
          <div class="flex flex-wrap gap-1.5">
            {post.data.tags.map((tag) => (
              <Badge variant="outline" client:load>{tag}</Badge>
            ))}
          </div>
        </div>

        {post.data.cover && (
          <img
            src={post.data.cover}
            alt={post.data.title}
            class="mb-0 aspect-video w-full rounded-xl shadow-card object-cover"
          />
        )}
      </div>
    </div>
  </div>

  <div class="w-full bg-[#f5f5f7] py-12 dark:bg-[#1C1C1E] md:py-16">
    <div class="site-container pb-20">
      <div class="prose prose-neutral prose-content mx-auto max-w-2xl dark:prose-invert">
        <Content />
      </div>
    </div>
  </div>
</BaseLayout>
