---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Hero } from '../components/Hero';
import { HomeWorkExperienceSection } from '../components/HomeWorkExperienceSection';
import { FeaturedProjects } from '../components/FeaturedProjects';
import { TechnicalSkillsSection } from '../components/TechnicalSkillsSection';
import { NextSection } from '../components/NextSection';
import { getCollection } from 'astro:content';

const workEntries = await getCollection('work');
---

<BaseLayout>
  <Hero client:load />
  <HomeWorkExperienceSection entries={workEntries} client:load />
  <TechnicalSkillsSection client:visible />
  <FeaturedProjects client:visible />
  <NextSection client:visible />
</BaseLayout>
