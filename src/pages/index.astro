---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Hero } from '../components/Hero';
import { HomeWorkExperienceSection } from '../components/HomeWorkExperienceSection';
import { MyJourneySection } from '../components/MyJourneySection';
import { TechnicalSkillsSection } from '../components/TechnicalSkillsSection';
import { getCollection } from 'astro:content';
import { workCollectionToTimelinePayload } from '../lib/workTimelinePayload';

const workEntriesPlain = workCollectionToTimelinePayload(await getCollection('work'));
---

<BaseLayout>
  <Hero client:load />
  <HomeWorkExperienceSection entries={workEntriesPlain} client:load />
  <TechnicalSkillsSection client:visible />
  <MyJourneySection client:visible />
</BaseLayout>

<script>
// Work Experience, animated wireframe mesh (CFD surface topology)
// Runs as a native Astro script to avoid React island useEffect timing issues.
// Astro scripts are deferred ES modules, load may have already fired, so check readyState.
function startWorkMesh() {
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

  const canvas = document.querySelector<HTMLCanvasElement>('#home-work-experience .we-mesh-canvas');
  const sect   = document.getElementById('home-work-experience');
  if (!canvas || !sect) return;

  const ctx = canvas.getContext('2d');
  if (!ctx) return;

  function resize() {
    canvas!.width  = sect!.offsetWidth;
    canvas!.height = sect!.offsetHeight;
  }
  resize();
  new ResizeObserver(resize).observe(sect);

  let t = 0;

  function draw() {
    const W = canvas!.width;
    const H = canvas!.height;
    if (!W || !H) { requestAnimationFrame(draw); return; }
    ctx!.clearRect(0, 0, W, H);

    const COLS = 22;
    const ROWS = 14;
    const cw   = W / COLS;
    const ch   = H / ROWS;

    // Sine-displaced grid, two overlapping wave frequencies create organic surface
    const grid: Array<Array<{ x: number; y: number }>> = [];
    for (let r = 0; r <= ROWS; r++) {
      grid[r] = [];
      for (let c = 0; c <= COLS; c++) {
        const nx = c / COLS;
        const ny = r / ROWS;
        const dy =
          Math.sin(nx * Math.PI * 2.8 + t)              * ch * 0.54 +
          Math.sin(ny * Math.PI * 1.9 + t * 0.6)        * ch * 0.38 +
          Math.sin((nx + ny) * Math.PI * 1.4 + t * 0.35) * ch * 0.22;
        grid[r][c] = { x: c * cw, y: r * ch + dy };
      }
    }

    ctx!.strokeStyle = 'rgba(55, 90, 172, 0.18)';
    ctx!.lineWidth   = 0.85;
    ctx!.beginPath();
    // Horizontal sweeps
    for (let r = 0; r <= ROWS; r++) {
      ctx!.moveTo(grid[r][0].x, grid[r][0].y);
      for (let c = 1; c <= COLS; c++) ctx!.lineTo(grid[r][c].x, grid[r][c].y);
    }
    // Vertical sweeps
    for (let c = 0; c <= COLS; c++) {
      ctx!.moveTo(grid[0][c].x, grid[0][c].y);
      for (let r = 1; r <= ROWS; r++) ctx!.lineTo(grid[r][c].x, grid[r][c].y);
    }
    ctx!.stroke();

    t += 0.003; // slow thermal drift ~180s per full cycle
    requestAnimationFrame(draw);
  }

  requestAnimationFrame(draw);
}

if (document.readyState === 'complete') {
  startWorkMesh();
} else {
  window.addEventListener('load', startWorkMesh, { once: true });
}
</script>
