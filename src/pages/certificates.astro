---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Certificates"
  description="Professional certifications, training, and credentials."
>
  <div class="site-container pt-14 pb-20">
    <div class="max-w-4xl">
      <h1 class="mb-4 text-5xl font-semibold tracking-[-0.04em] text-foreground md:text-6xl">
        Certificates
      </h1>
      <p class="max-w-3xl text-base leading-relaxed text-text-secondary md:text-lg">
        A dedicated place for certifications, course completions, and other credentials. Add images or PDFs here as you build out this page.
      </p>
    </div>

    <section class="mt-14" aria-label="Certificate gallery">
      <div
        class="theme-panel rounded-[1.25rem] border border-dashed border-border/80 p-10 text-center text-sm leading-relaxed text-text-muted md:p-14"
      >
        <p>Your certificates will appear here.</p>
      </div>
    </section>
  </div>
</BaseLayout>
