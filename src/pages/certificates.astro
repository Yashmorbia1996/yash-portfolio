---
import BaseLayout from '../layouts/BaseLayout.astro';

const professionalCerts = [
  {
    title: 'Certified SolidWorks Associate',
    abbr: 'CSWA',
    issuer: 'Dassault Systèmes (SolidWorks)',
    skills: ['3D Modelling', 'Part Design', 'Assembly', 'Engineering Drawing'],
    image: '/images/certificates/cswa.png',
    href: '/images/certificates/cswa.png',
    type: 'image',
  },
  {
    title: 'Certified SolidWorks Professional',
    abbr: 'CSWP',
    issuer: 'Dassault Systèmes (SolidWorks)',
    skills: ['Advanced Modelling', 'Configurations', 'Sheet Metal', 'Weldments'],
    image: '/images/certificates/cswp.png',
    href: '/images/certificates/cswp.png',
    type: 'image',
  },
];

/** Pursuing, shown in hero row next to Ongoing development */
const inProgressCerts = [
  {
    title: 'Six Sigma: white, yellow, and green belts',
    context: 'Lean Six Sigma',
    note: 'Working through white, yellow, and green belt levels.',
  },
  {
    title: 'Technologist (GDTP-Technologist)',
    context: 'ASME GDTP',
    note: 'ASME GD&T Technologist certification in progress.',
  },
] as const;

const courseCerts = [
  {
    title: 'CFD, SolidWorks Flow Simulation, ANSYS & Optimization',
    abbr: 'CFD · ANSYS',
    issuer: 'Udemy',
    skills: ['CFD', 'SolidWorks Flow Simulation', 'ANSYS Fluent', 'Design Optimisation'],
    image: '/images/certificates/cfd-solidworks-ansys-optimization.png',
    href: '/images/certificates/cfd-solidworks-ansys-optimization.pdf',
  },
  {
    title: 'GD&T Basics',
    abbr: 'GD&T',
    issuer: 'Udemy',
    skills: ['Geometric Dimensioning & Tolerancing', 'Technical Drawing', 'Manufacturing'],
    image: '/images/certificates/gdt-basics-udemy.png',
    href: '/images/certificates/gdt-basics-udemy.pdf',
  },
  {
    title: 'ISO 13485:2016, Medical Device Quality Management',
    abbr: 'ISO 13485',
    issuer: 'Professional Training',
    skills: ['ISO 13485', 'QMS', 'Regulatory Compliance', 'Medical Devices'],
    image: '/images/certificates/iso-13485-2016.png',
    href: '/images/certificates/iso-13485-2016.pdf',
  },
];
---

<BaseLayout
  title="Certifications"
  description="Professional certifications and course completions in mechanical engineering, CAD, simulation, and quality management."
>
  <div class="w-full bg-white dark:bg-black">
    <div class="site-container pt-14 pb-4 md:pb-6">
      <div class="w-full max-w-none">
        <h1 class="mb-4 text-5xl font-semibold tracking-tight text-[#1d1d1f] md:text-6xl dark:text-white">
          Certifications
        </h1>
        <p class="text-base leading-relaxed text-[#86868b] md:text-lg dark:text-[#A1A1A6]">
          Professional credentials and completed training in engineering, simulation, and quality systems.
        </p>
        <div
          class="mt-8 grid w-full grid-cols-1 gap-6 md:mt-10 md:grid-cols-2 md:items-stretch md:gap-8"
        >
          <div
            class="flex h-full flex-col justify-center rounded-2xl border border-border/80 bg-surface-elevated/50 p-5 sm:p-6"
          >
            <p class="font-mono text-[10px] font-semibold uppercase tracking-[0.16em] text-text-muted sm:text-[11px]">
              Ongoing development
            </p>
            <p class="mt-2 text-sm leading-relaxed text-text-secondary sm:text-base">
              I keep my formal credentials current, add course certificates as training completes, and stay pointed toward
              the next industry-relevant exams (for example, Six Sigma and ASME GD&amp;T) so the profile here matches what
              I can bring to a team on day one.
            </p>
          </div>
          <div
            class="flex h-full flex-col rounded-2xl border border-border/80 bg-surface-elevated/50 p-5 sm:p-6"
            aria-label="Certifications in progress"
          >
            <p class="font-mono text-[10px] font-semibold uppercase tracking-[0.16em] text-text-muted sm:text-[11px]">
              Pursuing next
            </p>
            <ul class="mt-4 list-none space-y-5 p-0">
              {inProgressCerts.map((item) => (
                <li>
                  <p class="mb-1 font-mono text-[10px] font-semibold uppercase tracking-[0.14em] text-primary-accent sm:text-[11px]">
                    {item.context}
                  </p>
                  <p class="text-sm font-semibold tracking-[-0.02em] text-text-primary sm:text-base">{item.title}</p>
                  <p class="mt-1 text-sm leading-relaxed text-text-secondary">{item.note}</p>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>

  <section class="w-full bg-[#f5f5f7] py-12 dark:bg-[#1C1C1E] md:py-16" aria-label="Professional credentials">
    <div class="site-container">
      <h2 class="theme-section-title mb-8 text-2xl font-semibold tracking-tight md:text-3xl">
        Professional Credentials
      </h2>
      <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
        {professionalCerts.map((cert) => (
          <a
            href={cert.href}
            target="_blank"
            rel="noopener noreferrer"
            class="group theme-panel theme-panel-hover block overflow-hidden rounded-2xl transition-all duration-300"
            style="text-decoration: none"
          >
            <div class="overflow-hidden rounded-t-2xl border-b border-border bg-white" style="aspect-ratio: 4/3;">
              <img
                src={cert.image}
                alt={cert.title}
                class="h-full w-full object-contain transition-transform duration-500 group-hover:scale-[1.02]"
              />
            </div>
            <div class="p-5">
              <p class="theme-eyebrow mb-1 font-mono text-[10px] font-semibold uppercase tracking-[0.16em]">
                {cert.abbr} · {cert.issuer}
              </p>
              <h3 class="mb-3 text-base font-semibold tracking-[-0.02em] text-text-primary transition-colors duration-200 group-hover:text-primary-accent">
                {cert.title}
              </h3>
              <p class="text-xs text-primary-accent">View certificate →</p>
            </div>
          </a>
        ))}
      </div>

    </div>
  </section>

  <section class="w-full border-t border-border bg-white py-12 dark:bg-black md:py-16" aria-label="Course completions">
    <div class="site-container pb-20">
      <h2 class="theme-section-title mb-8 text-2xl font-semibold tracking-tight md:text-3xl">
        Course Completions & Training
      </h2>
      <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
        {courseCerts.map((cert) => (
          <a
            href={cert.href}
            target="_blank"
            rel="noopener noreferrer"
            class="group theme-panel theme-panel-hover block overflow-hidden rounded-2xl transition-all duration-300"
            style="text-decoration: none"
          >
            <div class="overflow-hidden rounded-t-2xl border-b border-border" style="aspect-ratio: 16/9;">
              <img
                src={cert.image}
                alt={cert.title}
                class="h-full w-full object-cover object-top transition-transform duration-500 group-hover:scale-[1.02]"
              />
            </div>
            <div class="p-5">
              <p class="theme-eyebrow mb-1 font-mono text-[10px] font-semibold uppercase tracking-[0.16em]">
                {cert.abbr} · {cert.issuer}
              </p>
              <h3 class="mb-3 text-sm font-semibold leading-snug tracking-[-0.01em] text-text-primary transition-colors duration-200 group-hover:text-primary-accent">
                {cert.title}
              </h3>
              <p class="text-xs text-primary-accent">View certificate →</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
