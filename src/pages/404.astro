---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Button } from '../components/ui/button';
---

<BaseLayout title="404 — Page Not Found">
  <div class="site-container flex flex-col items-center justify-center min-h-[70vh] text-center py-20">
    <p class="text-xs font-semibold uppercase tracking-[0.08em] text-muted-foreground mb-4">
      404
    </p>
    <h1 class="font-heading text-4xl md:text-5xl font-normal tracking-[-0.03em] mb-4">
      Page not found
    </h1>
    <p class="text-muted-foreground mb-8 max-w-sm">
      The page you're looking for doesn't exist or has been moved.
    </p>
    <Button asChild client:load>
      <a href="/">Go home</a>
    </Button>
  </div>
</BaseLayout>
