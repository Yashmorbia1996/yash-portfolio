---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Button } from '../components/ui/button';
---

<BaseLayout title="404 | Page Not Found">
  <div class="w-full bg-[#f5f5f7] py-20 dark:bg-[#1C1C1E] md:py-28">
    <div class="site-container flex min-h-[60vh] flex-col items-center justify-center pb-20 text-center">
      <p class="mb-4 text-xs font-semibold uppercase tracking-[0.08em] text-[#86868b] dark:text-[#A1A1A6]">
        404
      </p>
      <h1 class="mb-4 font-heading text-4xl font-semibold tracking-tight text-[#1d1d1f] md:text-5xl dark:text-white">
        Page not found
      </h1>
      <p class="mb-8 max-w-sm text-[#86868b] dark:text-[#A1A1A6]">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <Button asChild client:load>
        <a href="/">Go home</a>
      </Button>
    </div>
  </div>
</BaseLayout>
